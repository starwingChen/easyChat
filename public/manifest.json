{
  "manifest_version": 3,
  "name": "EasyChat",
  "description": "Compare multiple AI assistants in one Chrome side panel.",
  "version": "1.2.1",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["sidePanel", "storage", "declarativeNetRequest", "cookies"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://copilot.microsoft.com/*",
    "wss://copilot.microsoft.com/*",
    "https://www.perplexity.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://*.deepseek.com/*",
    "https://dashscope.aliyuncs.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "copilot_websocket_headers",
        "enabled": true,
        "path": "rules/copilot-websocket-headers.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open EasyChat",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+J",
        "windows": "Alt+J",
        "mac": "Alt+J"
      }
    }
  }
}

{
  "manifest_version": 3,
  "name": "OmniChat",
  "description": "Compare multiple AI assistants in one Chrome side panel.",
  "version": "0.1.0",
  "permissions": ["sidePanel", "storage", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open OmniChat"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "commands": {
    "open-side-panel": {
      "description": "Open the OmniChat side panel"
    }
  }
}
